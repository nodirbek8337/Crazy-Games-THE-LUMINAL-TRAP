  - m_Id: 1000000000054
    m_Localized: E
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000055
    m_Localized: ...Men chiqib ketdimmi?
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000056
    m_Localized: Bu joy... tugadimi?
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000057
    m_Localized: Nega hali ham yuragim qo'rqyapti...?
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000058
    m_Localized: ...Unda nega hali ham ularning ovozlarini eshityapman?
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000059
    m_Localized: Qayt...
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000060
    m_Localized: Xayrulla... sen chiqa oldingmi...?
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000065
    m_Localized: "\u2014 So\u2018nggi yangiliklar \u2014 Bugun tongda shahardagi
      eski turar joy binolaridan birining liftida 27 yoshli Xayrulla ismli erkak
      o\u2018lik holda topildi. Qo\u2018shnilarining aytishicha, u taxminan bir hafta
      davomida uyidan chiqmagan. Ammo tergov davomida uning kvartirasida yashaganiga
      oid deyarli hech qanday iz topilmadi. Mutaxassislar hali ham bir savol ustida
      bosh qotirmoqda: Xayrulla haqiqatan ham bir hafta davomida uyida bo\u2018lganmi
      yoki shu vaqt ichida odamlar \u201CLuminal Trap\u201D deb atayotgan noma\u2019lum
      joyda adashib yurganmi? Eng qo\u2018rqinchlisi esa bu birinchi holat emas.
      So\u2018nggi oylar ichida liftlar bilan bog\u2018liq sirli hodisalar soni keskin
      oshib bormoqda. Guvohlarning aytishicha, hodisalardan oldin jabrlanuvchilar
      o\u2018zlari bilan gaplashishni boshlashgan va noma\u2019lum odamlardan xatlar
      olayotganini aytishgan. Politsiya bu hodisalarga hali ham rasmiy izoh bera
      olmagan. Ammo internet foydalanuvchilari orasida bitta nom tobora ko\u2018proq
      tarqalmoqda \u2014 \u201CLuminal Trap\u201D. Ba\u2019zilar buni ruhiy kasallik
      desa, boshqalar bu joyga kirgan odam asta-sekin haqiqatni yo\u2018qota boshlashini
      aytmoqda. Va eng g\u2018alati tomoni \u2014 topilgan barcha xatlarning oxirida
      qurbonlarning o\u2018z ismlari yozilgan edi."
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000021
    m_Localized: Bugun ham tinch uxlay olmadim...
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000022
    m_Localized: Balki bir haftadan beri uyimdan chiqmaganim uchundir.
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000023
    m_Localized: Bir aylanib kelsam, o'zimga kelib qolarman.
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000024
    m_Localized: Nimadir noto'g'ri...
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000025
    m_Localized: Boshim g'alati bo'lyapti.
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000026
    m_Localized: $2d#... nima bu, qavatmi?
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000027
    m_Localized: Bir haftadan beri uyimdan chiqmaganim yetmaganday, endi lift ham
      aqldan ozdimi?
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000028
    m_Localized: Mayli... nima bo'lsa ham.
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000029
    m_Localized: Nima bo'lyapti?!
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000030
    m_Localized: To'xta... TO'XTA!
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000031
    m_Localized: TO'XTA DEDIM!
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000032
    m_Localized: Nimalar bo'lyapti o'zi?!
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000033
    m_Localized: OVQAT
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000034
    m_Localized: ORTINGGA QAYT
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000035
    m_Localized: YOLG'ON
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000036
    m_Localized: PUSHAYMON
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000037
    m_Localized: ULAR SENI DOIM KUZATISHGAN
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000038
    m_Localized: PASTGA TUSHMA
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000039
    m_Localized: QO'RQUVINGNI YASHIR
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000040
    m_Localized: ...Men qayerdaman?
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000041
    m_Localized: Menga nima bo'ldi...
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000042
    m_Localized: Bularning hammasi o'sha lanati pomidorlar sabab bo'ldi.
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000043
    m_Localized: Ularning ayniganini sezgandim... yemasligim kerak edi.
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000044
    m_Localized: To'xta... bu nima o'zi?!
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000045
    m_Localized: Liftni ham buzib tashlashibdi.
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000046
    m_Localized: Nega endi 0-qavatni ko'rsatyapsan?!
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000047
    m_Localized: Men tezroq bu yerdan chiqishim kerak.
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000048
    m_Localized: Siz
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000049
    m_Localized: Xayrulla
    m_Metadata:
