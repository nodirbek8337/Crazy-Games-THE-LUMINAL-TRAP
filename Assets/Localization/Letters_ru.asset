  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: Letters_ru
  m_EditorClassIdentifier: 
  m_LocaleId:
    m_Code: ru
  m_SharedData: {fileID: 11400000, guid: 5f809af1881443b98088bbca1f90f563, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 1000000000001
    m_Localized: "Если ты читаешь
      эту запись, значит
      лифт привёл сюда
      и тебя. Меня зовут
      Xayrulla. Я уже давно искал
      это место. Я собирал
      информацию о пропавших
      людях, несуществующих
      этажах и странных
      случаях с лифтами.
      Сначала я думал,
      что всё это просто
      выдумки. Но оказалось,
      что они действительно
      существуют. Это
      место ненормальное.
      Этажи меняются.
      Комнаты тоже не
      всегда остаются
      одинаковыми. Иногда
      появляются очень
      мелкие изменения.
      Поэтому всегда
      внимательно смотри
      по сторонам. Если
      увидишь что-то
      необычное, спускайся
      вниз. Если всё выглядит
      нормально, продолжай
      подниматься вверх.
      Возможно, именно
      этот путь сможет
      вывести тебя отсюда.
      И запомни ещё кое-что...
      В этом месте есть
      какие-то существа.
      Они питаются твоим
      страхом. Поэтому
      всегда скрывай
      свой страх и никогда
      не приближайся
      к ним. Я видел их
      всего один раз.
      С тех пор они не
      перестают преследовать
      меня. Будто кто-то
      постоянно идёт
      у меня за спиной.
      Иногда они шепчут
      мне на ухо: \"Ты не
      сможешь уйти.\" \"Ты
      останешься с нами.\"
      \"Ты тоже станешь
      моей игрушкой,
      как и остальные.\"
      Если найдёшь другие
      мои записи, обязательно
      прочитай их. Я оставляю
      всё, что смог узнать.
      Возможно, это поможет
      нам обоим. — Xayrulla"
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000002
    m_Localized: "Если ты нашёл
      эту запись, значит
      ты всё ещё жив. Я
      пытаюсь понять
      некоторые вещи
      в этом месте. Это
      место наблюдает
      за тобой. Внимательно
      смотри по сторонам
      в коридорах. Иногда
      появляется то,
      чего раньше не
      было. А иногда наоборот
      — вещи исчезают.
      Особенно обращай
      внимание на двери.
      Если какое-то место
      кажется неправильным,
      не оставайся там
      надолго. И запомни
      ещё кое-что... Если
      увидишь вдалеке
      что-то похожее
      на неподвижного
      человека — не смотри
      на него слишком
      долго. Особенно
      если оно смотрит
      на тебя. Мне кажется,
      они не двигаются,
      пока ты смотришь
      на них. Но стоит
      тебе отвести взгляд
      — они меняют своё
      место. Вчера я увидел
      одного из них возле
      лифта. Когда двери
      лифта закрывались,
      я заметил, что у
      него не было лица.
      С тех пор мне иногда
      кажется, будто
      кто-то стоит у меня
      за спиной. А иногда
      я слышу дыхание
      рядом с ухом. Если
      я больше не оставлю
      записей... значит,
      возможно, они нашли
      меня. — Xayrulla"
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000003
    m_Localized: "Это моё третье
      письмо. Я не знаю,
      найдёшь ли ты его.
      Я очень устал. Я
      дошёл до 8 этажа.
      Но они обманули
      меня. И теперь я
      снова на 1 этаже.
      Я больше не понимаю
      правил этого места.
      Иногда кажется,
      будто коридоры
      становятся длиннее.
      А иногда, когда
      двери лифта открываются,
      внутри ничего нет.
      Мне начинают мерещиться
      разные вещи. Иногда
      я вижу кого-то вдалеке.
      Но когда смотрю
      туда — никого нет.
      Что-то наблюдает
      за мной. Я это чувствую.
      Мои ноги тоже перестают
      меня слушаться.
      Я пытаюсь остановиться,
      но всё равно продолжаю
      подниматься вверх.
      Мне страшно. Я жалею.
      Зачем я пришёл
      сюда? Зачем я искал
      всё это? Мне это
      было нужно? Что
      я вообще делаю?
      Я... я... кто я такой?
      Почему я здесь?
      Пожалуйста... помогите
      мне... пожалуйста..."
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
