--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: AnomalyHints_ru
  m_EditorClassIdentifier: 
  m_LocaleId:
    m_Code: ru
  m_SharedData: {fileID: 11400000, guid: c34e31861ecb4782ab0934cc2b9af179, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 2000000000001
    m_Localized: "Аномалии нет"
    m_Metadata:
      m_Items: []
  - m_Id: 2000000000018
    m_Localized: "Аномалия: Количество вентиляционных отверстий на этаже увеличилось. Вы точно помните, что раньше их было меньше."
    m_Metadata:
      m_Items: []
  - m_Id: 2000000000019
    m_Localized: "Аномалия: На этаже играет неизвестная музыка. Возможно, иногда стоит остановиться и просто послушать её."
    m_Metadata:
      m_Items: []
  - m_Id: 2000000000020
    m_Localized: "Аномалия: Весь дом окутан густым дымом. Возможно, именно так выглядят последствия курения."
    m_Metadata:
      m_Items: []
  - m_Id: 2000000000002
    m_Localized: "Аномалия: На вашем этаже появился дополнительный коридор, которого раньше здесь не было. Это место не соответствует изначальной структуре здания."
    m_Metadata:
      m_Items: []
  - m_Id: 2000000000003
    m_Localized: "Аномалия: Расположение картин на этаже изменилось. Вы помните, что раньше они висели иначе."
    m_Metadata:
      m_Items: []
  - m_Id: 2000000000004
    m_Localized: "Аномалия: Все двери на вашем этаже исчезли. Это место больше не выглядит как раньше."
    m_Metadata:
      m_Items: []
  - m_Id: 2000000000005
    m_Localized: "Аномалия: В конце коридора появились мусорные пакеты, которых раньше здесь не было."
    m_Metadata:
      m_Items: []
  - m_Id: 2000000000006
    m_Localized: "Аномалия: В одном из коридоров появилась странная стена, сузившая проход."
    m_Metadata:
      m_Items: []
  - m_Id: 2000000000007
    m_Localized: "Аномалия: В темноте в конце коридора вас ждёт неизвестное существо. Приближаться к нему не рекомендуется."
    m_Metadata:
      m_Items: []
  - m_Id: 2000000000008
    m_Localized: "Аномалия: Не доверяйте стуку, доносящемуся из-за двери. Тех, кто открывал её, ждала только смерть."
    m_Metadata:
      m_Items: []
  - m_Id: 2000000000009
    m_Localized: "Аномалия: Внутри этажа появилось странное облако. Иногда из него бьют молнии."
    m_Metadata:
      m_Items: []
  - m_Id: 2000000000010
    m_Localized: "Аномалия: Освещение на этаже странным образом становится красным. Причина этого явления неизвестна."
    m_Metadata:
      m_Items: []
  - m_Id: 2000000000011
    m_Localized: "Аномалия: Вчера одна из дверей на этаже странно двигалась. Человек, подошедший к ней, погиб после внезапного взрыва двери."
    m_Metadata:
      m_Items: []
  - m_Id: 2000000000012
    m_Localized: "Аномалия: На этаже появились мусорные пакеты в необычных местах."
    m_Metadata:
      m_Items: []
  - m_Id: 2000000000013
    m_Localized: "Аномалия: В вентиляционной системе произошла неисправность. Из неё вылетают электрические искры."
    m_Metadata:
      m_Items: []
  - m_Id: 2000000000014
    m_Localized: "Аномалия: Дверь странным образом изменила своё положение и повернулась на 90 градусов. Причина этого неизвестна."
    m_Metadata:
      m_Items: []
  - m_Id: 2000000000015
    m_Localized: "Аномалия: Перед лифтом появились мусорные пакеты, которых раньше здесь не было."
    m_Metadata:
      m_Items: []
  - m_Id: 2000000000016
    m_Localized: "Аномалия: Мелкие частицы пыли, постоянно находившиеся в воздухе, внезапно исчезли."
    m_Metadata:
      m_Items: []
  - m_Id: 2000000000017
    m_Localized: "Аномалия: На этаже погас весь свет. Возможно, стоило оплатить электричество."
    m_Metadata:
      m_Items: []
