    m_Metadata:
      m_Items: []
  - m_Id: 1000000000055
    m_Localized: "...\u042F \u0432\u044B\u0431\u0440\u0430\u043B\u0441\u044F?"
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000056
    m_Localized: "\u042D\u0442\u043E \u043C\u0435\u0441\u0442\u043E... \u0437\u0430\u043A\u043E\u043D\u0447\u0438\u043B\u043E\u0441\u044C?"
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000057
    m_Localized: "\u041F\u043E\u0447\u0435\u043C\u0443 \u043C\u043E\u0451 \u0441\u0435\u0440\u0434\u0446\u0435
      \u0432\u0441\u0451 \u0435\u0449\u0451 \u0431\u043E\u0438\u0442\u0441\u044F...?"
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000058
    m_Localized: "...\u0422\u043E\u0433\u0434\u0430 \u043F\u043E\u0447\u0435\u043C\u0443
      \u044F \u0432\u0441\u0451 \u0435\u0449\u0451 \u0441\u043B\u044B\u0448\u0443
      \u0438\u0445 \u0433\u043E\u043B\u043E\u0441\u0430?"
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000059
    m_Localized: "\u0412\u0435\u0440\u043D\u0438\u0441\u044C..."
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000060
    m_Localized: "Xayrulla... \u0442\u0435\u0431\u0435 \u0443\u0434\u0430\u043B\u043E\u0441\u044C
      \u0432\u044B\u0431\u0440\u0430\u0442\u044C\u0441\u044F...?"
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000065
    m_Localized: "\u2014 \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u043D\u043E\u0432\u043E\u0441\u0442\u0438
      \u2014 \u0421\u0435\u0433\u043E\u0434\u043D\u044F \u0443\u0442\u0440\u043E\u043C
      \u0432 \u043B\u0438\u0444\u0442\u0435 \u043E\u0434\u043D\u043E\u0433\u043E
      \u0438\u0437 \u0441\u0442\u0430\u0440\u044B\u0445 \u0436\u0438\u043B\u044B\u0445
      \u0434\u043E\u043C\u043E\u0432 \u0433\u043E\u0440\u043E\u0434\u0430 \u0431\u044B\u043B
      \u043D\u0430\u0439\u0434\u0435\u043D \u043C\u0451\u0440\u0442\u0432\u044B\u043C
      27-\u043B\u0435\u0442\u043D\u0438\u0439 \u043C\u0443\u0436\u0447\u0438\u043D\u0430
      \u043F\u043E \u0438\u043C\u0435\u043D\u0438 \u0425\u0430\u0439\u0440\u0443\u043B\u043B\u0430.
      \u041F\u043E \u0441\u043B\u043E\u0432\u0430\u043C \u0441\u043E\u0441\u0435\u0434\u0435\u0439,
      \u043E\u043D \u043E\u043A\u043E\u043B\u043E \u043D\u0435\u0434\u0435\u043B\u0438
      \u043D\u0435 \u0432\u044B\u0445\u043E\u0434\u0438\u043B \u0438\u0437 \u0441\u0432\u043E\u0435\u0439
      \u043A\u0432\u0430\u0440\u0442\u0438\u0440\u044B. \u041E\u0434\u043D\u0430\u043A\u043E
      \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u0440\u0430\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F
      \u0432 \u0435\u0433\u043E \u043A\u0432\u0430\u0440\u0442\u0438\u0440\u0435
      \u043F\u043E\u0447\u0442\u0438 \u043D\u0435 \u0431\u044B\u043B\u043E \u043D\u0430\u0439\u0434\u0435\u043D\u043E
      \u0441\u043B\u0435\u0434\u043E\u0432 \u0442\u043E\u0433\u043E, \u0447\u0442\u043E
      \u043E\u043D \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E
      \u0436\u0438\u043B \u0442\u0430\u043C \u0432\u0441\u0451 \u044D\u0442\u043E
      \u0432\u0440\u0435\u043C\u044F. \u0421\u043F\u0435\u0446\u0438\u0430\u043B\u0438\u0441\u0442\u044B
      \u0434\u043E \u0441\u0438\u0445 \u043F\u043E\u0440 \u043F\u044B\u0442\u0430\u044E\u0442\u0441\u044F
      \u043E\u0442\u0432\u0435\u0442\u0438\u0442\u044C \u043D\u0430 \u043E\u0434\u0438\u043D
      \u0432\u043E\u043F\u0440\u043E\u0441: \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E
      \u043B\u0438 \u0425\u0430\u0439\u0440\u0443\u043B\u043B\u0430 \u043F\u0440\u043E\u0432\u0451\u043B
      \u043D\u0435\u0434\u0435\u043B\u044E \u0443 \u0441\u0435\u0431\u044F \u0434\u043E\u043C\u0430
      \u0438\u043B\u0438 \u0432\u0441\u0451 \u044D\u0442\u043E \u0432\u0440\u0435\u043C\u044F
      \u0431\u043B\u0443\u0436\u0434\u0430\u043B \u0432 \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u043C
      \u043C\u0435\u0441\u0442\u0435, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
      \u043B\u044E\u0434\u0438 \u043D\u0430\u0437\u044B\u0432\u0430\u044E\u0442 \xABLuminal
      Trap\xBB? \u0421\u0430\u043C\u043E\u0435 \u043F\u0443\u0433\u0430\u044E\u0449\u0435\u0435
      \u2014 \u044D\u0442\u043E \u043D\u0435 \u043F\u0435\u0440\u0432\u044B\u0439
      \u043F\u043E\u0434\u043E\u0431\u043D\u044B\u0439 \u0441\u043B\u0443\u0447\u0430\u0439.
      \u0417\u0430 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u043C\u0435\u0441\u044F\u0446\u044B
      \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u043E \u0437\u0430\u0433\u0430\u0434\u043E\u0447\u043D\u044B\u0445
      \u043F\u0440\u043E\u0438\u0441\u0448\u0435\u0441\u0442\u0432\u0438\u0439, \u0441\u0432\u044F\u0437\u0430\u043D\u043D\u044B\u0445
      \u0441 \u043B\u0438\u0444\u0442\u0430\u043C\u0438, \u0440\u0435\u0437\u043A\u043E
      \u0443\u0432\u0435\u043B\u0438\u0447\u0438\u043B\u043E\u0441\u044C. \u041F\u043E
      \u0441\u043B\u043E\u0432\u0430\u043C \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u0435\u0439,
      \u043F\u0435\u0440\u0435\u0434 \u043F\u0440\u043E\u0438\u0441\u0448\u0435\u0441\u0442\u0432\u0438\u0435\u043C
      \u0436\u0435\u0440\u0442\u0432\u044B \u043D\u0430\u0447\u0438\u043D\u0430\u043B\u0438
      \u0440\u0430\u0437\u0433\u043E\u0432\u0430\u0440\u0438\u0432\u0430\u0442\u044C
      \u0441\u0430\u043C\u0438 \u0441 \u0441\u043E\u0431\u043E\u0439 \u0438 \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B\u0438,
      \u0447\u0442\u043E \u043F\u043E\u043B\u0443\u0447\u0430\u044E\u0442 \u043F\u0438\u0441\u044C\u043C\u0430
      \u043E\u0442 \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445
      \u043B\u044E\u0434\u0435\u0439. \u041F\u043E\u043B\u0438\u0446\u0438\u044F
      \u0434\u043E \u0441\u0438\u0445 \u043F\u043E\u0440 \u043D\u0435 \u043C\u043E\u0436\u0435\u0442
      \u0434\u0430\u0442\u044C \u043E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E
      \u043E\u0431\u044A\u044F\u0441\u043D\u0435\u043D\u0438\u044F \u044D\u0442\u0438\u043C
      \u0441\u043E\u0431\u044B\u0442\u0438\u044F\u043C. \u041E\u0434\u043D\u0430\u043A\u043E
      \u0441\u0440\u0435\u0434\u0438 \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u0439
      \u0438\u043D\u0442\u0435\u0440\u043D\u0435\u0442\u0430 \u0432\u0441\u0451 \u0447\u0430\u0449\u0435
      \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u044F\u0435\u0442\u0441\u044F
      \u043E\u0434\u043D\u043E \u043D\u0430\u0437\u0432\u0430\u043D\u0438\u0435 \u2014
      \xABLuminal Trap\xBB. \u041E\u0434\u043D\u0438 \u0441\u0447\u0438\u0442\u0430\u044E\u0442
      \u044D\u0442\u043E \u043F\u0441\u0438\u0445\u0438\u0447\u0435\u0441\u043A\u0438\u043C
      \u0440\u0430\u0441\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u043E\u043C,
      \u0434\u0440\u0443\u0433\u0438\u0435 \u0433\u043E\u0432\u043E\u0440\u044F\u0442,
      \u0447\u0442\u043E \u0447\u0435\u043B\u043E\u0432\u0435\u043A, \u043F\u043E\u043F\u0430\u0432\u0448\u0438\u0439
      \u0442\u0443\u0434\u0430, \u043F\u043E\u0441\u0442\u0435\u043F\u0435\u043D\u043D\u043E
      \u0442\u0435\u0440\u044F\u0435\u0442 \u0441\u0432\u044F\u0437\u044C \u0441
      \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C\u044E. \u0418
      \u0441\u0430\u043C\u043E\u0435 \u0441\u0442\u0440\u0430\u043D\u043D\u043E\u0435
      \u2014 \u0432 \u043A\u043E\u043D\u0446\u0435 \u0432\u0441\u0435\u0445 \u043D\u0430\u0439\u0434\u0435\u043D\u043D\u044B\u0445
      \u043F\u0438\u0441\u0435\u043C \u0431\u044B\u043B\u0438 \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u044B
      \u0438\u043C\u0435\u043D\u0430 \u0441\u0430\u043C\u0438\u0445 \u0436\u0435\u0440\u0442\u0432."
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000021
    m_Localized: "\u042F \u0441\u043D\u043E\u0432\u0430 \u043D\u0435 \u0441\u043C\u043E\u0433
      \u043D\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E \u0443\u0441\u043D\u0443\u0442\u044C..."
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000022
    m_Localized: "\u041D\u0430\u0432\u0435\u0440\u043D\u043E\u0435, \u043F\u043E\u0442\u043E\u043C\u0443
      \u0447\u0442\u043E \u044F \u0443\u0436\u0435 \u043D\u0435\u0434\u0435\u043B\u044E
      \u043D\u0435 \u0432\u044B\u0445\u043E\u0434\u0438\u043B \u0438\u0437 \u043A\u0432\u0430\u0440\u0442\u0438\u0440\u044B."
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000023
    m_Localized: "\u041C\u043E\u0436\u0435\u0442, \u043D\u0435\u0431\u043E\u043B\u044C\u0448\u0430\u044F
      \u043F\u0440\u043E\u0433\u0443\u043B\u043A\u0430 \u043F\u043E\u043C\u043E\u0436\u0435\u0442
      \u043F\u0440\u0438\u0439\u0442\u0438 \u0432 \u0441\u0435\u0431\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000024
    m_Localized: "\u0427\u0442\u043E-\u0442\u043E \u043D\u0435 \u0442\u0430\u043A..."
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000025
    m_Localized: "\u0413\u043E\u043B\u043E\u0432\u0430 \u043A\u0430\u043A\u0430\u044F-\u0442\u043E
      \u0441\u0442\u0440\u0430\u043D\u043D\u0430\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000026
    m_Localized: "$2d#... \u042D\u0442\u043E \u0447\u0442\u043E, \u043D\u043E\u043C\u0435\u0440
      \u044D\u0442\u0430\u0436\u0430?"
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000027
    m_Localized: "\u042F \u043D\u0435\u0434\u0435\u043B\u044E \u043D\u0435 \u0432\u044B\u0445\u043E\u0434\u0438\u043B
      \u0438\u0437 \u0434\u043E\u043C\u0430, \u0438 \u0442\u0435\u043F\u0435\u0440\u044C
      \u0435\u0449\u0451 \u0438 \u043B\u0438\u0444\u0442 \u0441 \u0443\u043C\u0430
      \u0441\u043E\u0448\u0451\u043B?"
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000028
    m_Localized: "\u041B\u0430\u0434\u043D\u043E... \u0431\u0443\u0434\u044C \u0447\u0442\u043E
      \u0431\u0443\u0434\u0435\u0442."
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000029
    m_Localized: "\u0427\u0442\u043E \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u0438\u0442?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000030
    m_Localized: "\u0421\u0442\u043E\u0439... \u0421\u0422\u041E\u0419!"
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000031
    m_Localized: "\u042F \u0421\u041A\u0410\u0417\u0410\u041B \u0421\u0422\u041E\u0419!"
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000032
    m_Localized: "\u041A\u0430\u043A\u043E\u0433\u043E \u0447\u0451\u0440\u0442\u0430
      \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u0438\u0442?!"
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000033
    m_Localized: "\u0415\u0414\u0410"
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000034
    m_Localized: "\u041E\u0411\u0415\u0420\u041D\u0418\u0421\u042C"
    m_Metadata:
      m_Items: []
  - m_Id: 1000000000035
    m_Localized: "\u041B\u041E\u0416\u042C"
    m_Metadata:
